{
  "schemaVersion": 1,
  "id": "spawner-utils",
  "version": "${version}",
  "name": "SpawnerUtils",
  "description": "Adds spawner ESP, ore ESP, player ESP and a NoClip module to Meteor Client.",
  "authors": ["YourNameHere"],
  "contact": {
    "sources": "https://github.com/yourname/spawner-utils"
  },
  "icon": "assets/template/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": ["com.example.addon.AddonTemplate"]
  },
  "mixins": ["spawner-utils.mixins.json"],
  "custom": {
    "meteor-client:color": "220,20,20"
  },
  "depends": {
    "java": ">=${jdk_version}",
    "minecraft": "${minecraft_version}",
    "meteor-client": "*"
  }
}
